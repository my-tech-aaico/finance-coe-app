DATABASE_URL=postgresql://user:password@localhost:5432/finance_db
BETTER_AUTH_SECRET=<32+ char random string>
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=<from Google Cloud Console>
GOOGLE_CLIENT_SECRET=<from Google Cloud Console>
ALLOWED_EMAIL_DOMAIN=growthops.asia,aaico.com
BOOTSTRAP_ADMIN_EMAILS=admin1@growthops.asia,admin2@growthops.asia

# Google Drive (service account) — used by claims/receipts/statements + schedulers
GOOGLE_SERVICE_ACCOUNT_EMAIL=<service-account>@<project>.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_PARENT_FOLDER_ID=<root folder id>
AUTHORIZED_USERS=user1@growthops.asia,user2@growthops.asia

# Opus Operator API (verification schedulers) — see guidelines/spec/opus-api.md
OPUS_API_URL=https://operator.opus.com
OPUS_SERVICE_KEY=<x-service-key value>
OPUS_WORKFLOW_ID=<workflow uuid>
OPUS_WORKFLOW_VERSION=37.0
# OPUS_CALLBACK_URL=            # optional, future use; omit to disable
OPUS_VAR_STATEMENT=<workflow input var name for the statement file>
OPUS_VAR_RECEIPTS=<workflow input var name for the receipts array>
OPUS_VAR_DESTINATION=<workflow input var name holding the literal "netsuite">
OPUS_VAR_NETSUITE_FOLDER=<workflow input var name for the netsuite folder id>
OPUS_REQUEST_TIMEOUT_MS=60000

# Verification scheduler tuning (defaults shown)
VERIFICATION_SUBMIT_BATCH_SIZE=5
VERIFICATION_POLL_BATCH_SIZE=5
VERIFICATION_SUBMIT_STUCK_MINUTES=60
VERIFICATION_INPROGRESS_TIMEOUT_HOURS=24

# Shared secret required on the x-cron-secret header for /api/cron/verification-submit,
# /api/cron/verification-poll, and /api/cron/project-code-sync — lets an external Linux cron
# box trigger these over HTTP against the Railway deployment. Generate with: openssl rand -hex 32
CRON_SECRET=9AJxSnr5F8EkcdK5XXGLUan6bPUbP/q2ZdZ2RWV3Hos=

# Project Code sync — reads a master Google Sheet and reconciles the project_code table.
# POST /api/cron/project-code-sync (x-cron-secret) or `pnpm project-code-sync`.
# The sheet must be shared (read) with GOOGLE_SERVICE_ACCOUNT_EMAIL.
PROJECT_CODE_SHEET_ID=1XTmPcuGPPiiBbC_71lx7BGnY5xWrYJ-O5gL57Aqtnf8
PROJECT_CODE_SHEET_TAB=<tab/sheet name>              # A1 ranges use the tab NAME, not a gid
PROJECT_CODE_HEADER_CODE=Project Code Ref            # header text for the code column
PROJECT_CODE_HEADER_TIMESTAMP=Timestamp              # header text for the timestamp column
PROJECT_CODE_HEADER_NAME=Project Name                # header text for the project-name column
